# csv | excel | google_sheets_csv | google_sheets_api | json
VITE_DATA_SOURCE=csv

# Excel: exporta tu hoja como CSV y colocala en public/porra.csv
VITE_EXCEL_CSV_PATH=/porra.csv

# Google Sheets publicado como CSV
VITE_GOOGLE_SHEET_CSV_URL=
VITE_GOOGLE_SHEET_ID=
VITE_GOOGLE_SHEET_GID=0

# Google Sheets API v4
VITE_GOOGLE_SHEETS_API_KEY=
VITE_GOOGLE_SHEET_RANGE=Clasificacion!A:D

# JSON propio opcional
VITE_LEADERBOARD_JSON_URL=
